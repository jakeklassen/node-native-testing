{
  "name": "node-testing",
  "version": "1.0.0",
  "description": "",
  "type": "module",
  "scripts": {
    "test": "node --test **/*/*.test.js",
    "test:tap": "node --test **/*/*.test.js | tap -",
    "test:ts": "node --test **/*/*.test.ts",
    "test:coverage": "node --experimental-test-coverage --test **/*/*.test.js",
    "test:watch": "node --watch --test",
    "typecheck": "tsc",
    "lint": "oxlint --type-aware",
    "lint:fix": "oxlint --type-aware --fix",
    "format": "oxfmt",
    "format:check": "oxfmt --check"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/node": "26.1.1",
    "oxfmt": "^0.59.0",
    "oxlint": "^1.73.0",
    "oxlint-tsgolint": "^7.0.0",
    "tap": "^21.6.3",
    "typescript": "^7.0.2"
  }
}
